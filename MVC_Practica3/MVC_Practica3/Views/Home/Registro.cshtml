@{
    ViewData["Title"] = "Registro";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header text-center">
            <h3>Registro</h3>
        </div>
        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form method="post" asp-action="Registro" asp-controller="Home"
                  id="formAbono">

                <div class="row mb-3 align-items-start">
                    <label class="col-sm-3 col-form-label fw-bold">Compra</label>
                    <div class="col-sm-6">
                        <select id="Id_Compra"
                                name="Id_Compra"
                                class="form-select"
                                required>
                        </select>
                    </div>
                    <div class="col-sm-3">
                        <a asp-action="Consulta" asp-controller="Home"
                           class="btn btn-secondary">
                            Consultar
                        </a>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label for="SaldoAnterior"
                           class="col-sm-3 col-form-label fw-bold">
                        Saldo Anterior
                    </label>
                    <div class="col-sm-6">
                        <input type="text"
                               id="SaldoAnterior"
                               class="form-control bg-light"
                               readonly />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label for="Monto"
                           class="col-sm-3 col-form-label fw-bold">
                        Abono
                    </label>
                    <div class="col-sm-6">
                        <input type="number"
                               id="Monto"
                               name="Monto"
                               class="form-control"
                               step="0.01"
                               min="0.01"
                               placeholder=""
                               required />
                        <div id="errorAbono" class="text-danger mt-1 d-none">
                            El abono no puede ser mayor al saldo anterior.
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-sm-9 offset-sm-0">
                        <button type="submit"
                                id="btnAbonar"
                                class="btn btn-secondary w-75">
                            Abonar
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/registro.js" asp-append-version="true"></script>
}
